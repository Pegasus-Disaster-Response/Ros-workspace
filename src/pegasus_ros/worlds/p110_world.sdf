<?xml version="1.0" ?>
<!--
  P110 Disaster Response World — Large Map (300×300m operational zone)
  Buildings, collapsed structures, mixed trees, vehicles, smoke/fire, rescue targets.
  Launch: gz sim ~/Ros-workspace/src/pegasus_ros/worlds/p110_world.sdf
-->
<sdf version="1.9">
  <world name="p110_world">

    <physics name="1ms" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <scene>
      <ambient>0.45 0.45 0.50 1.0</ambient>
      <background>0.55 0.70 0.85 1.0</background>
      <shadows>true</shadows>
      <sky>
        <time>10</time><sunrise>6</sunrise><sunset>20</sunset>
        <clouds><speed>8</speed><mean_size>0.5</mean_size><ambient>0.82 0.82 0.82 1</ambient></clouds>
      </sky>
      <fog>
        <color>0.78 0.82 0.88 1</color><type>linear</type>
        <start>80</start><end>300</end><density>0.008</density>
      </fog>
    </scene>

    <atmosphere type="adiabatic">
      <temperature>295</temperature><pressure>101325</pressure>
      <temperature_gradient>-0.0065</temperature_gradient>
    </atmosphere>

    <plugin filename="gz-sim-physics-system"        name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-user-commands-system"  name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-particle-emitter-system" name="gz::sim::systems::ParticleEmitter"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>50 80 100 0 0 0</pose>
      <diffuse>1.0 0.98 0.92 1</diffuse>
      <specular>0.8 0.78 0.72 1</specular>
      <direction>-0.4 -0.3 -0.9</direction>
    </light>

    <!-- Secondary fill light (ambient bounce from sky) -->
    <light type="directional" name="sky_fill">
      <cast_shadows>false</cast_shadows>
      <pose>0 0 50 0 0 0</pose>
      <diffuse>0.35 0.42 0.55 1</diffuse>
      <specular>0.0 0.0 0.0 1</specular>
      <direction>0.1 0.1 -1</direction>
    </light>

    <!-- ════════════════════════════════════════════════════════════
         GROUND & TERRAIN
         ════════════════════════════════════════════════════════════ -->

    <model name="ground_base"><static>true</static>
      <link name="link">
        <collision name="c"><geometry><plane><normal>0 0 1</normal><size>700 700</size></plane></geometry></collision>
        <visual name="v"><geometry><plane><normal>0 0 1</normal><size>700 700</size></plane></geometry>
          <material><ambient>0.42 0.34 0.24 1</ambient><diffuse>0.50 0.40 0.28 1</diffuse><specular>0.05 0.04 0.03 1</specular></material>
        </visual>
      </link>
    </model>

    <!-- Terrain shoulders rising around perimeter -->
    <model name="tmound_nw"><static>true</static><pose>-90 85 1.1 0 0 0.3</pose>
      <link name="link"><collision name="c"><geometry><box><size>80 60 2.2</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>80 60 2.2</size></box></geometry>
          <material><ambient>0.40 0.33 0.22 1</ambient><diffuse>0.48 0.39 0.26 1</diffuse></material></visual>
      </link></model>
    <model name="tmound_ne"><static>true</static><pose>88 88 0.9 0 0 -0.2</pose>
      <link name="link"><collision name="c"><geometry><box><size>75 65 1.8</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>75 65 1.8</size></box></geometry>
          <material><ambient>0.38 0.32 0.21 1</ambient><diffuse>0.46 0.38 0.25 1</diffuse></material></visual>
      </link></model>
    <model name="tmound_se"><static>true</static><pose>90 -88 0.7 0 0 0.1</pose>
      <link name="link"><collision name="c"><geometry><box><size>70 60 1.4</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>70 60 1.4</size></box></geometry>
          <material><ambient>0.36 0.30 0.20 1</ambient><diffuse>0.44 0.36 0.24 1</diffuse></material></visual>
      </link></model>
    <model name="tmound_sw"><static>true</static><pose>-90 -88 1.0 0 0 -0.15</pose>
      <link name="link"><collision name="c"><geometry><box><size>80 65 2.0</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>80 65 2.0</size></box></geometry>
          <material><ambient>0.40 0.33 0.22 1</ambient><diffuse>0.48 0.39 0.26 1</diffuse></material></visual>
      </link></model>

    <!-- Road surfaces (3 E-W + 3 N-S) -->
    <model name="road_ew_main"><static>true</static><pose>0 0 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>280 9 0.08</size></box></geometry>
          <material><ambient>0.26 0.26 0.26 1</ambient><diffuse>0.32 0.32 0.32 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual></link></model>
    <model name="road_ew_n"><static>true</static><pose>0 50 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>260 7 0.08</size></box></geometry>
          <material><ambient>0.27 0.27 0.27 1</ambient><diffuse>0.33 0.33 0.33 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual></link></model>
    <model name="road_ew_s"><static>true</static><pose>0 -50 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>260 7 0.08</size></box></geometry>
          <material><ambient>0.27 0.27 0.27 1</ambient><diffuse>0.33 0.33 0.33 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual></link></model>
    <model name="road_ns_main"><static>true</static><pose>0 0 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>9 280 0.08</size></box></geometry>
          <material><ambient>0.26 0.26 0.26 1</ambient><diffuse>0.32 0.32 0.32 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual></link></model>
    <model name="road_ns_e"><static>true</static><pose>55 0 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>7 260 0.08</size></box></geometry>
          <material><ambient>0.27 0.27 0.27 1</ambient><diffuse>0.33 0.33 0.33 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual></link></model>
    <model name="road_ns_w"><static>true</static><pose>-55 0 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>7 260 0.08</size></box></geometry>
          <material><ambient>0.27 0.27 0.27 1</ambient><diffuse>0.33 0.33 0.33 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual></link></model>

    <!-- Ground patches: grass, dirt, rubble -->
    <model name="grass_park_se"><static>true</static><pose>80 -65 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>35 30 0.06</size></box></geometry>
          <material><ambient>0.22 0.40 0.14 1</ambient><diffuse>0.26 0.48 0.17 1</diffuse></material></visual></link></model>
    <model name="grass_park_sw"><static>true</static><pose>-80 -65 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>30 25 0.06</size></box></geometry>
          <material><ambient>0.20 0.38 0.13 1</ambient><diffuse>0.24 0.46 0.16 1</diffuse></material></visual></link></model>
    <model name="grass_courtyard_n"><static>true</static><pose>-15 68 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>20 15 0.06</size></box></geometry>
          <material><ambient>0.21 0.39 0.13 1</ambient><diffuse>0.25 0.47 0.16 1</diffuse></material></visual></link></model>
    <model name="grass_median"><static>true</static><pose>28 25 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>12 8 0.06</size></box></geometry>
          <material><ambient>0.22 0.38 0.14 1</ambient><diffuse>0.26 0.46 0.17 1</diffuse></material></visual></link></model>
    <model name="dirt_blast_c"><static>true</static><pose>10 8 0.05 0 0 0.3</pose>
      <link name="link"><visual name="v"><geometry><box><size>22 18 0.06</size></box></geometry>
          <material><ambient>0.48 0.36 0.22 1</ambient><diffuse>0.56 0.42 0.26 1</diffuse></material></visual></link></model>
    <model name="dirt_blast_w"><static>true</static><pose>-38 12 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>20 25 0.06</size></box></geometry>
          <material><ambient>0.46 0.34 0.20 1</ambient><diffuse>0.54 0.40 0.24 1</diffuse></material></visual></link></model>
    <model name="rubble_ground_c"><static>true</static><pose>-5 -15 0.05 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>18 14 0.06</size></box></geometry>
          <material><ambient>0.58 0.50 0.38 1</ambient><diffuse>0.66 0.56 0.44 1</diffuse></material></visual></link></model>

    <!-- Flood zone (standing water) -->
    <model name="flood_zone"><static>true</static><pose>-12 -22 0.06 0 0 0</pose>
      <link name="link"><visual name="v"><geometry><box><size>20 14 0.12</size></box></geometry>
          <material><ambient>0.14 0.28 0.52 0.65</ambient><diffuse>0.18 0.34 0.60 0.65</diffuse><specular>0.50 0.55 0.62 1</specular></material></visual></link></model>

    <!-- ════════════════════════════════════════════════════════════
         MAJOR BUILDINGS (12 structures across 300m map)
         ════════════════════════════════════════════════════════════ -->

    <!-- B1: Large damaged warehouse — NW industrial zone (raised to 42m) -->
    <model name="warehouse_1"><static>true</static><pose>-65 70 21 0 0 0.15</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>24 18 42</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>24 18 42</size></box></geometry>
          <material><ambient>0.55 0.45 0.35 1</ambient><diffuse>0.62 0.50 0.38 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual>
        <visual name="upper_damage"><pose>0 0 14 0 0 0</pose><geometry><box><size>24 18 14</size></box></geometry>
          <material><ambient>0.48 0.40 0.32 1</ambient><diffuse>0.55 0.45 0.35 1</diffuse></material></visual>
        <visual name="corner_break"><pose>10 7 18 0.15 -0.2 0</pose><geometry><box><size>6 4 12</size></box></geometry>
          <material><ambient>0.44 0.36 0.28 1</ambient><diffuse>0.52 0.42 0.32 1</diffuse></material></visual>
      </link>
    </model>

    <!-- B2: Tall office tower — center zone (raised to 50m) -->
    <model name="office_tower"><static>true</static><pose>20 22 25 0 0 0.25</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>14 14 50</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>14 14 50</size></box></geometry>
          <material><ambient>0.50 0.50 0.52 1</ambient><diffuse>0.58 0.58 0.62 1</diffuse><specular>0.18 0.18 0.20 1</specular></material></visual>
        <visual name="face_e"><pose>7 0 0 0 0 0</pose><geometry><box><size>0.4 14 50</size></box></geometry>
          <material><ambient>0.44 0.44 0.48 1</ambient><diffuse>0.50 0.50 0.56 1</diffuse><specular>0.20 0.20 0.22 1</specular></material></visual>
        <visual name="face_w"><pose>-7 0 0 0 0 0</pose><geometry><box><size>0.4 14 50</size></box></geometry>
          <material><ambient>0.44 0.44 0.48 1</ambient><diffuse>0.50 0.50 0.56 1</diffuse><specular>0.20 0.20 0.22 1</specular></material></visual>
        <visual name="blast_hole"><pose>0 -6.5 -6 0 0 0</pose><geometry><box><size>6 1 8</size></box></geometry>
          <material><ambient>0.25 0.22 0.20 1</ambient><diffuse>0.30 0.26 0.22 1</diffuse></material></visual>
      </link>
    </model>

    <!-- B3: Modern glass building — east zone (raised to 40m) -->
    <model name="modern_building"><static>true</static><pose>75 -18 20 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>18 12 40</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>18 12 40</size></box></geometry>
          <material><ambient>0.52 0.56 0.58 1</ambient><diffuse>0.60 0.64 0.68 1</diffuse><specular>0.22 0.22 0.24 1</specular></material></visual>
        <visual name="glass_n"><pose>0 6.2 0 0 0 0</pose><geometry><box><size>18 0.8 40</size></box></geometry>
          <material><ambient>0.65 0.70 0.75 0.7</ambient><diffuse>0.70 0.75 0.80 0.7</diffuse><specular>0.40 0.40 0.40 1</specular></material></visual>
      </link>
    </model>

    <!-- B4: Residential complex — SW zone (raised to 35m) -->
    <model name="residential_1"><static>true</static><pose>-68 -45 17.5 0 0 -0.1</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>22 14 35</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>22 14 35</size></box></geometry>
          <material><ambient>0.58 0.48 0.42 1</ambient><diffuse>0.68 0.56 0.48 1</diffuse><specular>0.12 0.10 0.10 1</specular></material></visual>
        <visual name="unit_l"><pose>-8 0 0 0 0 0</pose><geometry><box><size>5 14 35</size></box></geometry>
          <material><ambient>0.52 0.44 0.38 1</ambient><diffuse>0.62 0.50 0.42 1</diffuse></material></visual>
        <visual name="unit_r"><pose>8 0 0 0 0 0</pose><geometry><box><size>5 14 35</size></box></geometry>
          <material><ambient>0.52 0.44 0.38 1</ambient><diffuse>0.62 0.50 0.42 1</diffuse></material></visual>
      </link>
    </model>

    <!-- B5: Clinic/hospital — NE zone (raised to 36m for SLAM facade coverage) -->
    <model name="clinic"><static>true</static><pose>55 72 18 0 0 0.3</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>14 10 36</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>14 10 36</size></box></geometry>
          <material><ambient>0.72 0.70 0.68 1</ambient><diffuse>0.82 0.80 0.78 1</diffuse><specular>0.18 0.18 0.18 1</specular></material></visual>
        <!-- Red cross stripe — mid-height on facade -->
        <visual name="cross_h"><pose>0 5.2 8 0 0 0</pose><geometry><box><size>4 0.3 1</size></box></geometry>
          <material><ambient>0.85 0.12 0.12 1</ambient><diffuse>0.90 0.15 0.15 1</diffuse></material></visual>
        <visual name="cross_v"><pose>0 5.2 8 0 0 0</pose><geometry><box><size>1 0.3 4</size></box></geometry>
          <material><ambient>0.85 0.12 0.12 1</ambient><diffuse>0.90 0.15 0.15 1</diffuse></material></visual>
      </link>
    </model>

    <!-- B6: Apartment block — south zone (raised to 38m) -->
    <model name="apartment_s"><static>true</static><pose>-18 -72 19 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>20 12 38</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>20 12 38</size></box></geometry>
          <material><ambient>0.54 0.46 0.40 1</ambient><diffuse>0.64 0.54 0.46 1</diffuse><specular>0.10 0.10 0.10 1</specular></material></visual>
        <visual name="balconies"><pose>0 6.2 0 0 0 0</pose><geometry><box><size>20 0.6 38</size></box></geometry>
          <material><ambient>0.48 0.42 0.36 1</ambient><diffuse>0.56 0.48 0.40 1</diffuse></material></visual>
      </link>
    </model>

    <!-- B7: Factory 2 — far east (raised to 32m, smokestack to 50m total) -->
    <model name="factory_e"><static>true</static><pose>95 35 16 0 0 0.4</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>28 20 32</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>28 20 32</size></box></geometry>
          <material><ambient>0.48 0.42 0.34 1</ambient><diffuse>0.56 0.48 0.40 1</diffuse><specular>0.08 0.08 0.08 1</specular></material></visual>
        <!-- Smokestack — rises 18m above factory roof (total ~50m) -->
        <visual name="stack"><pose>10 6 25 0 0 0</pose><geometry><cylinder><radius>1.2</radius><length>36</length></cylinder></geometry>
          <material><ambient>0.38 0.35 0.32 1</ambient><diffuse>0.45 0.42 0.38 1</diffuse></material></visual>
      </link>
    </model>

    <!-- B8: School building — west zone (raised to 28m) -->
    <model name="school_w"><static>true</static><pose>-88 18 14 0 0 -0.05</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>30 15 28</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>30 15 28</size></box></geometry>
          <material><ambient>0.60 0.54 0.44 1</ambient><diffuse>0.70 0.62 0.50 1</diffuse><specular>0.12 0.12 0.10 1</specular></material></visual>
        <visual name="wing"><pose>-18 -8 -3 0 0 0</pose><geometry><box><size>6 14 22</size></box></geometry>
          <material><ambient>0.58 0.52 0.42 1</ambient><diffuse>0.68 0.60 0.48 1</diffuse></material></visual>
      </link>
    </model>

    <!-- B9: Shopping centre — SE zone (raised to 30m tall urban mall) -->
    <model name="shopping_se"><static>true</static><pose>38 -68 15 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>35 22 30</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>35 22 30</size></box></geometry>
          <material><ambient>0.56 0.54 0.50 1</ambient><diffuse>0.65 0.62 0.58 1</diffuse><specular>0.15 0.15 0.14 1</specular></material></visual>
        <visual name="canopy"><pose>0 0 15.2 0 0 0</pose><geometry><box><size>35 22 0.4</size></box></geometry>
          <material><ambient>0.45 0.44 0.40 1</ambient><diffuse>0.54 0.52 0.48 1</diffuse></material></visual>
      </link>
    </model>

    <!-- B10: Hotel tower — far north -->
    <model name="hotel_n"><static>true</static><pose>8 95 22 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>16 12 44</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>16 12 44</size></box></geometry>
          <material><ambient>0.60 0.60 0.62 1</ambient><diffuse>0.68 0.68 0.72 1</diffuse><specular>0.22 0.22 0.24 1</specular></material></visual>
        <visual name="glass_e"><pose>8.2 0 0 0 0 0</pose><geometry><box><size>0.6 12 44</size></box></geometry>
          <material><ambient>0.50 0.60 0.70 0.7</ambient><diffuse>0.55 0.65 0.75 0.7</diffuse><specular>0.35 0.35 0.40 1</specular></material></visual>
      </link>
    </model>

    <!-- B11: Community centre — far south (raised to 25m) -->
    <model name="community_s"><static>true</static><pose>-45 -88 12.5 0 0 0.2</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>25 18 25</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>25 18 25</size></box></geometry>
          <material><ambient>0.58 0.52 0.44 1</ambient><diffuse>0.68 0.60 0.50 1</diffuse><specular>0.10 0.10 0.08 1</specular></material></visual>
      </link>
    </model>

    <!-- B12: Warehouse 2 — far NW (raised to 32m) -->
    <model name="warehouse_2"><static>true</static><pose>-90 88 16 0 0 -0.3</pose>
      <link name="link">
        <collision name="c"><geometry><box><size>30 20 32</size></box></geometry></collision>
        <visual name="main"><geometry><box><size>30 20 32</size></box></geometry>
          <material><ambient>0.50 0.44 0.36 1</ambient><diffuse>0.58 0.50 0.42 1</diffuse><specular>0.08 0.08 0.08 1</specular></material></visual>
      </link>
    </model>

    <!-- ════════════════════════════════════════════════════════════
         COLLAPSED BUILDINGS — Multi-part realistic collapses
         Each uses: standing remnant + tilted floor slabs + wall
         fragments + dense rubble base
         ════════════════════════════════════════════════════════════ -->

    <!-- COLLAPSE 1: North wing of warehouse_1 (major collapse) -->
    <!-- Standing south wall remnant -->
    <model name="col1_wall_s"><static>true</static><pose>-68 56 9 0 0 0.15</pose>
      <link name="link"><collision name="c"><geometry><box><size>20 0.6 18</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>20 0.6 18</size></box></geometry>
          <material><ambient>0.50 0.42 0.34 1</ambient><diffuse>0.58 0.48 0.38 1</diffuse></material></visual></link></model>
    <!-- East wall partial standing -->
    <model name="col1_wall_e"><static>true</static><pose>-57 62 6 0 0.12 0.18</pose>
      <link name="link"><collision name="c"><geometry><box><size>0.6 14 12</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>0.6 14 12</size></box></geometry>
          <material><ambient>0.48 0.40 0.32 1</ambient><diffuse>0.56 0.46 0.36 1</diffuse></material></visual></link></model>
    <!-- Fallen floor slab 1 — large angled concrete -->
    <model name="col1_slab1"><static>true</static><pose>-62 66 2.2 0.45 0.05 0.2</pose>
      <link name="link"><collision name="c"><geometry><box><size>16 10 0.4</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>16 10 0.4</size></box></geometry>
          <material><ambient>0.46 0.46 0.46 1</ambient><diffuse>0.54 0.54 0.54 1</diffuse><specular>0.08 0.08 0.08 1</specular></material></visual></link></model>
    <!-- Fallen floor slab 2 — steeper, at bottom -->
    <model name="col1_slab2"><static>true</static><pose>-70 68 1.2 -0.55 0.08 0.25</pose>
      <link name="link"><collision name="c"><geometry><box><size>14 8 0.4</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>14 8 0.4</size></box></geometry>
          <material><ambient>0.44 0.44 0.44 1</ambient><diffuse>0.52 0.52 0.52 1</diffuse></material></visual></link></model>
    <!-- Fallen wall fragment — lying flat -->
    <model name="col1_wall_fallen"><static>true</static><pose>-64 72 0.5 1.5708 0.1 0.3</pose>
      <link name="link"><collision name="c"><geometry><box><size>12 0.5 6</size></box></geometry></collision>
        <visual name="v"><geometry><box><size>12 0.5 6</size></box></geometry>
          <material><ambient>0.50 0.42 0.34 1</ambient><diffuse>0.58 0.48 0.38 1</diffuse></material></visual></link></model>
    <!-- Dense rubble pile at collapse base -->
    <model name="col1_rubble_a"><static>true</static><pose>-66 68 1.8 0.1 0.05 0.4</pose>
      <link name="link"><collision name="c"><geometry><box><size>18 14 3.5</size></box></geometry></collision>
