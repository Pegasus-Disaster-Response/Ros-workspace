    <model name="hotel_win_n1"><static>true</static><pose>8 101.1 8 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>14 0.15 1.8</size></box></geometry><material><ambient>0.48 0.55 0.65 0.85</ambient><diffuse>0.52 0.60 0.72 0.85</diffuse><specular>0.45 0.45 0.50 1</specular></material></visual></link></model>
    <model name="hotel_win_n2"><static>true</static><pose>8 101.1 18 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>14 0.15 1.8</size></box></geometry><material><ambient>0.48 0.55 0.65 0.85</ambient><diffuse>0.52 0.60 0.72 0.85</diffuse><specular>0.45 0.45 0.50 1</specular></material></visual></link></model>
    <model name="hotel_win_n3"><static>true</static><pose>8 101.1 28 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>14 0.15 1.8</size></box></geometry><material><ambient>0.48 0.55 0.65 0.85</ambient><diffuse>0.52 0.60 0.72 0.85</diffuse><specular>0.45 0.45 0.50 1</specular></material></visual></link></model>
    <model name="hotel_win_n4"><static>true</static><pose>8 101.1 38 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>14 0.15 1.8</size></box></geometry><material><ambient>0.48 0.55 0.65 0.85</ambient><diffuse>0.52 0.60 0.72 0.85</diffuse><specular>0.45 0.45 0.50 1</specular></material></visual></link></model>

    <!-- Modern building east face (x=75+9=84): 4 window bands -->
    <model name="mbldg_win_e1"><static>true</static><pose>84.1 -18 8 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>0.15 10 1.8</size></box></geometry><material><ambient>0.55 0.62 0.70 0.8</ambient><diffuse>0.60 0.68 0.76 0.8</diffuse><specular>0.45 0.45 0.50 1</specular></material></visual></link></model>
    <model name="mbldg_win_e2"><static>true</static><pose>84.1 -18 20 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>0.15 10 1.8</size></box></geometry><material><ambient>0.55 0.62 0.70 0.8</ambient><diffuse>0.60 0.68 0.76 0.8</diffuse><specular>0.45 0.45 0.50 1</specular></material></visual></link></model>
    <model name="mbldg_win_e3"><static>true</static><pose>84.1 -18 32 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>0.15 10 1.8</size></box></geometry><material><ambient>0.55 0.62 0.70 0.8</ambient><diffuse>0.60 0.68 0.76 0.8</diffuse><specular>0.45 0.45 0.50 1</specular></material></visual></link></model>

    <!-- Apartment south face (y=-72+6=-66): 4 window bands -->
    <model name="apt_win_n1"><static>true</static><pose>-18 -65.9 8 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>18 0.15 1.8</size></box></geometry><material><ambient>0.44 0.38 0.32 1</ambient><diffuse>0.52 0.44 0.36 1</diffuse></material></visual></link></model>
    <model name="apt_win_n2"><static>true</static><pose>-18 -65.9 18 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>18 0.15 1.8</size></box></geometry><material><ambient>0.44 0.38 0.32 1</ambient><diffuse>0.52 0.44 0.36 1</diffuse></material></visual></link></model>
    <model name="apt_win_n3"><static>true</static><pose>-18 -65.9 28 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>18 0.15 1.8</size></box></geometry><material><ambient>0.44 0.38 0.32 1</ambient><diffuse>0.52 0.44 0.36 1</diffuse></material></visual></link></model>


    <!-- ════════════════════════════════════════════════════════════
         AERIAL MOVING OBSTACLES — D* Lite 3D replanner stress test.
         All objects operate at or above 25m AGL (SEARCH_ALTITUDE).
         ════════════════════════════════════════════════════════════ -->

    <!-- Static crane tower at (35, 40) — yellow steel structure -->
    <model name="crane_tower"><static>true</static><pose>35 40 15 0 0 0</pose>
      <link name="link">
        <!-- Main mast: 30m tall -->
        <visual name="mast"><geometry><cylinder><radius>0.6</radius><length>30</length></cylinder></geometry>
          <material><ambient>0.80 0.65 0.05 1</ambient><diffuse>0.90 0.72 0.06 1</diffuse><specular>0.30 0.24 0.04 1</specular></material></visual>
        <!-- Cab at top of mast (z=30, half-length=15, centre=15 → offset 15) -->
        <visual name="cab"><pose>0 0 15 0 0 0</pose><geometry><box><size>3 3 3</size></box></geometry>
          <material><ambient>0.78 0.62 0.04 1</ambient><diffuse>0.88 0.70 0.05 1</diffuse></material></visual>
        <!-- Counterweight boom stub (rear, -x direction) -->
        <visual name="cw_boom"><pose>-4 0 15.5 0 0 0</pose><geometry><box><size>6 0.4 0.4</size></box></geometry>
          <material><ambient>0.78 0.62 0.04 1</ambient><diffuse>0.88 0.70 0.05 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Crane arm actor — 20m boom rotating at 32m AGL, 36s period.
         Pose is the arm CENTRE; boom half-length = 10m from pivot.
         Absolute z = tower base (35→pose 15, mast top = 30m from centre = 15+15=30) + 2m overhang = 32m
         Actor centre at (35, 40, 32). -->
    <actor name="crane_arm">
      <pose>35 40 32 0 0 0</pose>
      <skin><filename>walk.dae</filename><scale>0.001</scale></skin>
      <link name="arm_link">
        <visual name="boom"><geometry><box><size>20 0.6 0.6</size></box></geometry>
          <material><ambient>0.80 0.65 0.05 1</ambient><diffuse>0.90 0.72 0.06 1</diffuse></material></visual>
        <visual name="hook_cable"><pose>9.5 0 -1.5 0 0 0</pose><geometry><cylinder><radius>0.08</radius><length>3</length></cylinder></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient><diffuse>0.30 0.30 0.30 1</diffuse></material></visual>
        <visual name="hook"><pose>9.5 0 -3.2 0 0 0</pose><geometry><sphere><radius>0.25</radius></sphere></geometry>
          <material><ambient>0.22 0.22 0.22 1</ambient><diffuse>0.28 0.28 0.28 1</diffuse></material></visual>
      </link>
      <script>
        <loop>true</loop>
        <delay_start>0.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="__default__">
          <!-- 12 steps × 3s = 36s full rotation -->
          <waypoint><time>0.0</time><pose>35 40 32 0 0 0.0000</pose></waypoint>
          <waypoint><time>3.0</time><pose>35 40 32 0 0 0.5236</pose></waypoint>
          <waypoint><time>6.0</time><pose>35 40 32 0 0 1.0472</pose></waypoint>
          <waypoint><time>9.0</time><pose>35 40 32 0 0 1.5708</pose></waypoint>
          <waypoint><time>12.0</time><pose>35 40 32 0 0 2.0944</pose></waypoint>
          <waypoint><time>15.0</time><pose>35 40 32 0 0 2.6180</pose></waypoint>
          <waypoint><time>18.0</time><pose>35 40 32 0 0 3.1416</pose></waypoint>
          <waypoint><time>21.0</time><pose>35 40 32 0 0 -2.6180</pose></waypoint>
          <waypoint><time>24.0</time><pose>35 40 32 0 0 -2.0944</pose></waypoint>
          <waypoint><time>27.0</time><pose>35 40 32 0 0 -1.5708</pose></waypoint>
          <waypoint><time>30.0</time><pose>35 40 32 0 0 -1.0472</pose></waypoint>
          <waypoint><time>33.0</time><pose>35 40 32 0 0 -0.5236</pose></waypoint>
          <waypoint><time>36.0</time><pose>35 40 32 0 0  0.0000</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- UAV actor 1 — East→West crossing at y=5, z=27m.
         Flies from x=120 to x=-120 in 35s, returns in 35s. -->
    <actor name="uav_cross_ew">
      <pose>120 5 27 0 0 3.1416</pose>
      <skin><filename>walk.dae</filename><scale>0.001</scale></skin>
      <link name="body_link">
        <!-- Fuselage -->
        <visual name="fuselage"><geometry><box><size>2.5 0.5 0.3</size></box></geometry>
          <material><ambient>0.20 0.20 0.22 1</ambient><diffuse>0.26 0.26 0.28 1</diffuse><specular>0.15 0.15 0.15 1</specular></material></visual>
        <!-- Wings -->
        <visual name="wings"><geometry><box><size>0.4 4.0 0.08</size></box></geometry>
          <material><ambient>0.18 0.18 0.20 1</ambient><diffuse>0.24 0.24 0.26 1</diffuse></material></visual>
        <!-- Red port nav light -->
        <visual name="nav_red"><pose>0 -2.1 0 0 0 0</pose><geometry><sphere><radius>0.12</radius></sphere></geometry>
          <material><ambient>0.95 0.05 0.05 1</ambient><diffuse>1.0 0.06 0.06 1</diffuse></material></visual>
        <!-- Green starboard nav light -->
        <visual name="nav_green"><pose>0 2.1 0 0 0 0</pose><geometry><sphere><radius>0.12</radius></sphere></geometry>
          <material><ambient>0.05 0.95 0.05 1</ambient><diffuse>0.06 1.0 0.06 1</diffuse></material></visual>
      </link>
      <script>
        <loop>true</loop>
        <delay_start>0.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="__default__">
          <waypoint><time>0.0</time><pose>120  5 27 0 0 3.1416</pose></waypoint>
          <waypoint><time>35.0</time><pose>-120  5 27 0 0 3.1416</pose></waypoint>
          <waypoint><time>35.1</time><pose>-120  5 27 0 0 0.0000</pose></waypoint>
          <waypoint><time>70.0</time><pose>120  5 27 0 0 0.0000</pose></waypoint>
          <waypoint><time>70.1</time><pose>120  5 27 0 0 3.1416</pose></waypoint>
        </trajectory>
      </script>
    </actor>

    <!-- UAV actor 2 — South→North crossing at x=25, z=30m.
         Flies from y=-120 to y=120 in 40s, returns in 40s.
         Intersects UAV-1 path near (25, 5) creating an airspace conflict. -->
    <actor name="uav_cross_sn">
      <pose>25 -120 30 0 0 1.5708</pose>
      <skin><filename>walk.dae</filename><scale>0.001</scale></skin>
      <link name="body_link">
        <!-- Fuselage — blue livery -->
        <visual name="fuselage"><geometry><box><size>2.5 0.5 0.3</size></box></geometry>
          <material><ambient>0.10 0.18 0.65 1</ambient><diffuse>0.14 0.22 0.78 1</diffuse><specular>0.20 0.20 0.30 1</specular></material></visual>
        <!-- Wings -->
        <visual name="wings"><geometry><box><size>0.4 4.0 0.08</size></box></geometry>
          <material><ambient>0.08 0.16 0.60 1</ambient><diffuse>0.12 0.20 0.72 1</diffuse></material></visual>
        <!-- White strobe -->
        <visual name="strobe"><pose>0 0 0.2 0 0 0</pose><geometry><sphere><radius>0.10</radius></sphere></geometry>
          <material><ambient>0.95 0.95 0.95 1</ambient><diffuse>1.0 1.0 1.0 1</diffuse></material></visual>
      </link>
      <script>
        <loop>true</loop>
        <delay_start>5.0</delay_start>
        <auto_start>true</auto_start>
        <trajectory id="0" type="__default__">
          <waypoint><time>0.0</time><pose>25 -120 30 0 0 1.5708</pose></waypoint>
          <waypoint><time>40.0</time><pose>25  120 30 0 0 1.5708</pose></waypoint>
          <waypoint><time>40.1</time><pose>25  120 30 0 0 -1.5708</pose></waypoint>
          <waypoint><time>80.0</time><pose>25 -120 30 0 0 -1.5708</pose></waypoint>
          <waypoint><time>80.1</time><pose>25 -120 30 0 0  1.5708</pose></waypoint>
        </trajectory>
      </script>
    </actor>

  </world>
</sdf>
