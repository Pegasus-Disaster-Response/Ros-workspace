    <!-- ════════════════════════════════════════════════════════════
         BRIDGE / OVERPASS
         Forces D* Lite to choose: fly over (>8m AGL) or fly under
         (clear height 5m). Spans main N-S road at y=-35.
         ════════════════════════════════════════════════════════════ -->

    <!-- West abutment -->
    <model name="bridge_abt_w"><static>true</static><pose>-8 -35 2.5 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><box><size>4 6 5</size></box></geometry></collision>
