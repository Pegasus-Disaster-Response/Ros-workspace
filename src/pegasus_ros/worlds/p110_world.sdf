          <material><ambient>0.15 0.15 0.15 1</ambient><diffuse>0.20 0.20 0.20 1</diffuse></material></visual></link></model>

    <!-- Cable span 2: across main E-W road at x=40, 4m and 6m — forces route decision -->
    <model name="cable_pole_2a"><static>true</static><pose>40 -6 3.0 0 0 0</pose>
