    <!-- ════════════════════════════════════════════════════════════
         PARTIAL ROOF / OVERHANG STRUCTURE
         Collapsed parking garage — roof slab with no walls on two
         sides. ZED X can't see under it; SLAM must dead-reckon.
         Position: south-west open area (-40, -35)
         ════════════════════════════════════════════════════════════ -->

    <!-- Four concrete columns -->
    <model name="prk_col_1"><static>true</static><pose>-32 -30 3.5 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>7</length></cylinder></geometry></collision>
