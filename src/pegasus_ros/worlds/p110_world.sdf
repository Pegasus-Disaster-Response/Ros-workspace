    <model name="prk_col_2"><static>true</static><pose>-20 -30 3.5 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>7</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.5</radius><length>7</length></cylinder></geometry>
          <material><ambient>0.52 0.52 0.52 1</ambient><diffuse>0.60 0.60 0.60 1</diffuse></material></visual></link></model>
    <model name="prk_col_3"><static>true</static><pose>-32 -44 3.5 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>7</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.5</radius><length>7</length></cylinder></geometry>
          <material><ambient>0.52 0.52 0.52 1</ambient><diffuse>0.60 0.60 0.60 1</diffuse></material></visual></link></model>
    <model name="prk_col_4"><static>true</static><pose>-20 -44 3.5 0 0 0</pose>
      <link name="link"><collision name="c"><geometry><cylinder><radius>0.5</radius><length>7</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.5</radius><length>7</length></cylinder></geometry>
          <material><ambient>0.52 0.52 0.52 1</ambient><diffuse>0.60 0.60 0.60 1</diffuse></material></visual></link></model>
    <!-- Roof slab (7.1m AGL, open east + west faces — no walls) -->
