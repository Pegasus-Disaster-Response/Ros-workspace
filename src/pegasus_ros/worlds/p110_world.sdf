    <model name="rwy_cl4"><static>true</static><pose>78 -110 0.10 0 0 0</pose><link name="link"><visual name="v"><geometry><box><size>8 0.4 0.02</size></box></geometry><material><ambient>0.95 0.95 0.95 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse></material></visual></link></model>
